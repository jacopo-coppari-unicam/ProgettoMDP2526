                                <Label fx:id="lblEnemyName" text="👹 NEMICO" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblEnemyHp" text="HP: 50/50" textFill="#ff414d">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
