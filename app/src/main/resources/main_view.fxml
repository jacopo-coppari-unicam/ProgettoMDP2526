                <TextArea fx:id="txtLogBattaglia" editable="false" prefHeight="260.0" prefWidth="770.0" style="-fx-control-inner-background: #111115; -fx-text-fill: #e0e0e6; -fx-font-family: 'Consolas'; -fx-font-size: 14px; -fx-border-color: #3f3f46;" wrapText="true">
                    <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                    </VBox.margin>
