                                        </Label>
                                        <HBox prefHeight="450.0" spacing="20.0">
                                            <children>
                                                <VBox prefWidth="425.0" spacing="10.0">
                                                    <children>
                                                        <Label text="Abilità Conosciute (Owned)" textFill="#fffffe">
                                                            <font>
                                                                <Font size="14.0" />
