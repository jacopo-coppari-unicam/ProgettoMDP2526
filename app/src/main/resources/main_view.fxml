                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Button fx:id="btnAttaccoBase" mnemonicParsing="false" onAction="#handleAttaccoBase" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #ff414d; -fx-background-radius: 5; -fx-cursor: hand;" text="⚔️ Attacco Base" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Button>
                        <VBox spacing="5.0">
                            <children>
                                <ListView fx:id="lvBattleSkills" prefHeight="100.0" prefWidth="220.0" style="-fx-background-color: #242429; -fx-control-inner-background: #242429;" />
                                <Button fx:id="btnUsaSkill" mnemonicParsing="false" onAction="#handleUsaSkill" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #9b59b6; -fx-background-radius: 5; -fx-cursor: hand;" text="🔮 Usa Skill Selezionata" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>
                            </children>
