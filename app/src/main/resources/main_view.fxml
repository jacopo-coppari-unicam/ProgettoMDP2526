<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg125571.view.MainDashboardController"
            prefWidth="1280.0"
            prefHeight="720.0"
            style="-fx-background-color: linear-gradient(to bottom, #1a1a1a, #2b2118);">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-background-color: #3a2a1d; -fx-border-color: gold; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>

            <Label text="⚔ RPG 125571 - HUB CENTRALE"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: gold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="goldLabel"  text="Gold: 0"  style="-fx-font-size: 18px; -fx-text-fill: #ffd700;"/>
            <Label fx:id="levelLabel" text="Level: 1" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- LEFT: SCHEDA PERSONAGGIO ED EQUIPAGGIAMENTO -->
    <left>
        <VBox spacing="12" prefWidth="280"
              style="-fx-background-color: #241b14; -fx-border-color: gold; -fx-border-width: 0 2 0 0;">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <Label text="STATUS EROE"
                   style="-fx-font-size: 20px; -fx-text-fill: gold; -fx-font-weight: bold;"/>

            <VBox spacing="5">
                <Label fx:id="playerNameLabel" text="Eroe Sconosciuto"
                       style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                <Label fx:id="hpLabel" text="HP: 100 / 100"
                       style="-fx-text-fill: #ff4d4d;"/>
                <ProgressBar fx:id="hpBar" progress="1.0" prefWidth="250"
                             style="-fx-accent: #ff4d4d;"/>
            </VBox>

            <GridPane hgap="10" vgap="5">
                <Label text="ATK:" style="-fx-text-fill: #ffaa66;"/>
                <Label fx:id="atkLabel" text="10" style="-fx-text-fill: white;" GridPane.columnIndex="1"/>
                <Label text="DEF:" style="-fx-text-fill: #66aaff;" GridPane.rowIndex="1"/>
                <Label fx:id="defLabel" text="5"  style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

            <Separator style="-fx-background-color: gold;"/>

            <Label text="Equipaggiamento"
                   style="-fx-font-size: 16px; -fx-text-fill: gold; -fx-font-weight: bold;"/>

            <!-- Tutti e 5 gli slot sempre visibili -->
            <GridPane hgap="10" vgap="8">
                <Label text="⚔ Weapon:" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="weaponSlotLabel" text="—" style="-fx-text-fill: #fff;" GridPane.columnIndex="1"/>

                <Label text="🪖 Helmet:"  style="-fx-text-fill: #ccc;" GridPane.rowIndex="1"/>
                <Label fx:id="helmetSlotLabel" text="—" style="-fx-text-fill: #fff;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="🥋 Chest:"   style="-fx-text-fill: #ccc;" GridPane.rowIndex="2"/>
                <Label fx:id="chestSlotLabel"  text="—" style="-fx-text-fill: #fff;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="👖 Legs:"    style="-fx-text-fill: #ccc;" GridPane.rowIndex="3"/>
                <Label fx:id="legsSlotLabel"   text="—" style="-fx-text-fill: #fff;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="👢 Boots:"   style="-fx-text-fill: #ccc;" GridPane.rowIndex="4"/>
                <Label fx:id="bootsSlotLabel"  text="—" style="-fx-text-fill: #fff;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </GridPane>

            <!-- NON c'è più il bottone "Gestisci Inventario" inutile -->
        </VBox>
    </left>

    <!-- CENTER: LOG, COMBATTIMENTO E INVENTARIO -->
    <center>
        <TabPane side="TOP" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: transparent;">

            <!-- TAB 1: ESPLORAZIONE & COMBATTIMENTO -->
            <Tab text="🗺️ Esplorazione &amp; Combattimento">
                <VBox alignment="CENTER" spacing="15" style="-fx-padding: 15;">
                    <Label text="DIARIO DI VIAGGIO"
                           style="-fx-font-size: 20px; -fx-text-fill: gold; -fx-font-weight: bold;"/>
                    <TextArea fx:id="eventLogArea"
                              editable="false"
                              prefWidth="600" prefHeight="320"
                              wrapText="true"
                              style="-fx-control-inner-background: #121212; -fx-text-fill: #00ff00; -fx-font-family: 'Consolas';"
                              promptText="Eventi di gioco, battaglie e dialoghi..."/>
                    <HBox alignment="CENTER" spacing="15">
                        <Button fx:id="searchEnemyButton" text="⚔️ Cerca Nemico"
                                prefWidth="180" onAction="#handleSearchEnemy"
                                style="-fx-background-color: #5a1a1a; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button fx:id="bossButton" text="👑 Sfida Boss"
                                prefWidth="180" onAction="#handleChallengeBoss"
                                style="-fx-background-color: #705000; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- TAB 2: INVENTARIO -->
            <Tab text="📦 Zaino Oggetti">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="IL TUO INVENTARIO"
                           style="-fx-font-size: 18px; -fx-text-fill: gold;"/>
                    <ListView fx:id="inventoryListView" VBox.vgrow="ALWAYS"
                              style="-fx-control-inner-background: #1f140e;"/>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="🛡️ Equipaggia"  onAction="#handleUseItem"
                                style="-fx-background-color: #2a5a1a; -fx-text-fill: white;"/>
                        <Button text="↩️ Disequipaggia" onAction="#handleUnequipItem"
                                style="-fx-background-color: #5a3a1a; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <!-- RIGHT: SKILL LOADOUT -->
    <right>
        <VBox spacing="15" prefWidth="300"
              style="-fx-background-color: #241b14; -fx-border-color: gold; -fx-border-width: 0 0 0 2;">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <Label text="SKILL LOADOUT"
                   style="-fx-font-size: 20px; -fx-text-fill: gold; -fx-font-weight: bold;"/>

            <Label text="Abilità Attive (in uso):" style="-fx-text-fill: #aaa;"/>
            <ListView fx:id="skillListView" prefHeight="200"
                      style="-fx-control-inner-background: #1f140e;"/>

            <Separator style="-fx-background-color: gold;"/>

            <Label text="Tutte le Skill Sbloccate:" style="-fx-text-fill: #aaa;"/>
            <ListView fx:id="allSkillsListView" VBox.vgrow="ALWAYS"
                      style="-fx-control-inner-background: #1f140e;"/>

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="equipSkillButton" text="⚡ Equipaggia"
                        onAction="#handleEquipSkill"
                        style="-fx-background-color: #1a3a5a; -fx-text-fill: white;"/>
                <Button fx:id="unequipSkillButton" text="❌ Rimuovi"
                        onAction="#handleUnequipSkill"
                        style="-fx-background-color: #444; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </right>

    <!-- BOTTOM BAR -->
    <bottom>
        <HBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #3a2a1d; -fx-border-color: gold; -fx-border-width: 2 0 0 0;">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Button fx:id="saveButton" text="💾 Salva Partita" onAction="#handleSaveGame"
                    style="-fx-background-color: #222; -fx-text-fill: white;"/>
            <Button fx:id="loadButton" text="📂 Carica Partita" onAction="#handleLoadGame"
                    style="-fx-background-color: #222; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="exitButton" text="🚪 Esci dal Gioco" onAction="#handleExit"
                    style="-fx-background-color: #aa2222; -fx-text-fill: white;"/>
        </HBox>
    </bottom>

</BorderPane>
