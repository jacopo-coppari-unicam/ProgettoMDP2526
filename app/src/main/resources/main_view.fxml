        <VBox fx:id="paneBattaglia" alignment="TOP_CENTER" prefHeight="650.0" prefWidth="850.0" spacing="20.0" style="-fx-background-color: rgba(22, 22, 26, 0.99);" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="⚔️ SCONTRO IN CORSO ⚔️" textFill="#ff414d">
                    <font>
                        <Font name="System Bold" size="30.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER" spacing="50.0">
                    <children>
                        <VBox alignment="CENTER" prefWidth="300.0" spacing="8.0" style="-fx-background-color: #242429; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #2ecc71; -fx-border-width: 1;">
                            <children>
                                <Label fx:id="lblBattlePlayerName" text="🛡️ GIOCATORE" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblBattlePlayerHp" text="HP: 100/100" textFill="#2ecc71">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefWidth="300.0" spacing="8.0" style="-fx-background-color: #242429; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ff414d; -fx-border-width: 1;">
