                                                        </Label>
                                                        <ListView fx:id="lvOwnedSkills" prefHeight="380.0" style="-fx-background-color: #242429; -fx-control-inner-background: #242429; -fx-background-radius: 5; -fx-border-color: #3f3f46; -fx-border-radius: 5;" />
                                                        <Button fx:id="btnEquipaggiaSkill" maxWidth="1.1796493E7" mnemonicParsing="false" onAction="#handleEquipaggiaSkill" prefHeight="40.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 5; -fx-cursor: hand;" text="Metti nel Loadout Attivo" textFill="WHITE">
                                                            <font>
                                                                <Font name="System Bold" size="14.0" />
                                                            </font>
                                                        </Button>
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="425.0" spacing="10.0">
                                                    <children>
                                                        <Label text="Loadout Equipaggiato (Pronto al Combattimento)" textFill="#fffffe">
                                                            <font>
                                                                <Font size="14.0" />
                                                            </font>
                                                        </Label>
                                                        <ListView fx:id="lvActiveLoadout" prefHeight="380.0" style="-fx-background-color: #242429; -fx-control-inner-background: #242429; -fx-background-radius: 5; -fx-border-color: #3f3f46; -fx-border-radius: 5;" />
                                                        <Button fx:id="btnRimuoviSkill" maxWidth="1.1796493E7" mnemonicParsing="false" onAction="#handleRimuoviSkill" prefHeight="40.0" style="-fx-background-color: #e74c3c; -fx-background-radius: 5; -fx-cursor: hand;" text="Rimuovi dal Loadout" textFill="WHITE">
                                                            <font>
                                                                <Font name="System Bold" size="14.0" />
                                                            </font>
                                                        </Button>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>
            </tabs>
