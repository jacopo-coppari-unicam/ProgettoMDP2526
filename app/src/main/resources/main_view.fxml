<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg125571.view.MainDashboardController"
            prefWidth="1280.0"
            prefHeight="720.0"
            style="-fx-background-color: linear-gradient(to bottom, #1a1a1a, #2b2118);">

    <top>
        <fx:include fx:id="statusView" source="status_view.fxml"/>
    </top>

    <left>
        <fx:include fx:id="characterView" source="character_view.fxml"/>
    </left>

    <center>
        <TabPane side="TOP" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent;">

            <Tab text="🗺️ Esplorazione &amp; Combattimento">
                <fx:include fx:id="combatView" source="combat_view.fxml"/>
            </Tab>

            <Tab text="📦 Zaino Oggetti">
                <fx:include fx:id="inventoryView" source="inventory_view.fxml"/>
            </Tab>

        </TabPane>
    </center>

    <right>
        <fx:include fx:id="skillView" source="skill_view.fxml"/>
    </right>

    <bottom>
        <fx:include fx:id="saveSystemView" source="savesystem_view.fxml"/>
    </bottom>

</BorderPane>