<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg125571.view.SaveSystemController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #3a2a1d; -fx-border-color: gold; -fx-border-width: 2 0 0 0;">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <Button fx:id="saveButton" text="💾 Salva Partita" onAction="#handleSaveGame"
            style="-fx-background-color: #222; -fx-text-fill: white;"/>
    <Button fx:id="loadButton" text="📂 Carica Partita" onAction="#handleLoadGame"
            style="-fx-background-color: #222; -fx-text-fill: white;"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button fx:id="exitButton" text="🚪 Esci dal Gioco" onAction="#handleExit"
            style="-fx-background-color: #aa2222; -fx-text-fill: white;"/>
</HBox>